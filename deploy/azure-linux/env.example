# Azure Blob or ADLS Gen2 container/filesystem root.
# Production uses the VM's system-assigned managed identity through the
# Azure Python SDK. The identity needs Storage Blob Data Contributor.
TIC_STORAGE_ROOT="https://sttic.blob.core.windows.net/tic-refresh"

# Repo checkout path on each VM.
TIC_REPO_ROOT="$HOME/PriceTransparency_Linux"

# Worker ephemeral disk path.
TIC_WORK_DIR="/mnt/resource/tic-refresh"

# Optional: override Python after setup.
TIC_PYTHON="$TIC_REPO_ROOT/.venv/bin/python3"
TIC_RUST_STREAM_PRICING="$TIC_REPO_ROOT/rust/stream_pricing_serde/target/release/stream_pricing_serde"

TIC_PAYER_CODE="UHC"
TIC_STATE="TX"

# Any signed UHC public-mrf blob URL. The coordinator extracts the SAS token
# and lists the monthly prefix, e.g. 2026-04-01/.
TIC_UHC_MRF_SEED_URL="https://uhc-tic-mrf.azureedge.net/public-mrf/2026-04-01/2026-04-01_1-AB-Inc_index.json?sv=2024-11-04&ss=b&srt=sco&sp=rwlitfx&se=2030-02-16T17:39:32Z&st=2026-02-16T09:24:32Z&spr=https&sig=1PcuH99nzLXbiaxh2perZSJub%2FTbVC5CB1wc9Y%2BaU7s%3D"

# Optional coordinator settings.
TIC_SHARDS="10"
TIC_SCAN_WORKERS="10"
